##remove duplicate peaks
def clean_peaklist(peaklist, min_rr_ms=300, fs=1024):
    cleaned = []
    cleaned_indices = []
    last_peak = None
    min_distance = int((min_rr_ms / 1000) * fs)

    for i, peak in enumerate(peaklist):
        if last_peak is None or (peak - last_peak) >= min_distance:
            cleaned.append(peak)
            cleaned_indices.append(i)
