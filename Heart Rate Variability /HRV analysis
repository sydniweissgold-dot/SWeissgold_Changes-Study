##define function for process_rr (essentially time-domain analysis with the rr-intervals that are output post manual peak detection)
def process_rr(rr_intervals_ms, label=''):
    # Convert input list to NumPy array and remove NaNs
    rr = np.array(rr_intervals_ms)
    rr = rr[~np.isnan(rr)]

    # Compute differences between successive RR intervals (for RMSSD, NN50, etc.)
    diff_rr = np.diff(rr)

    # Count number of adjacent RR intervals that differ by more than 50ms (NN50)
    nn50 = np.sum(np.abs(diff_rr) > 50)

    # Calculate percentage of NN50 over total RR differences
    pnn50 = 100.0 * nn50 / len(diff_rr)

    # Standard deviation of RR intervals (SDNN)
    sdnn = np.std(rr)

    # Root mean square of successive differences (RMSSD)
    rmssd = np.sqrt(np.mean(diff_rr**2))

    # Average RR interval (AVNN) and its inverse in beats per minute (BPM)
    avnn = np.mean(rr)
    ibi = avnn
    bpm = 60000.0 / avnn if avnn != 0 else 0

    # Poincaré plot SD1 and SD2 (nonlinear HRV features)
    sd1 = np.sqrt(np.std(diff_rr, ddof=1)**2 / 2)
    sd2 = np.sqrt(2 * std(rr, ddof=1)**2 - sd1**2)

    # Ratio of SD1 to SD2
    sd1sd2 = sd1 / sd2 if sd2 != 0 else np.nan

    # Combine time-domain measures into a dictionary
    time_metrics = {
        'RMSSD (ms)': rmssd,
        'SDNN (ms)': sdnn,
        'AVNN (ms)': avnn,
        'IBI (ms)': ibi,
        'BPM': bpm,
        'NN50': nn50,
        'pNN50 (%)': pnn50,
        'SD1 (ms)': sd1,
        'SD2 (ms)': sd2,
        'SD1/SD2': sd1sd2
    }

    # Get frequency domain features using separate function
    freq_metrics = frequency_domain_measures(rr)

    # Merge and return all HRV metrics
    all_metrics = {**time_metrics, **freq_metrics}
    return all_metrics

##define funtion to do frequency based analysis (welch's method) with rr-intervals
def frequency_domain_measures(rr_intervals_ms):
    # Convert RR list to NumPy array and remove NaNs
    rr = np.array(rr_intervals_ms)
    rr = rr[~np.isnan(rr)]  # Remove NaN values (NaN = not a number)

    # Convert from ms to seconds for processing (for frequency calculation) (*necessary bc frequency calculations i.e. PSD are done in sec)
    rr_sec = rr / 1000.0  # Convert to seconds for PSD calculation

    # Create time axis by cumulatively summing intervals
    time_sec = np.cumsum(rr_sec)
    time_sec -= time_sec[0]  # Start at 0

    # Interpolate RR data to a constant frequency (4Hz)
    freq = 4.0
    interpolated_time = np.arange(0, time_sec[-1], 1.0 / freq)

    # Interpolation using cubic spline
    interp_func = interp1d(time_sec, rr_sec, kind='cubic')
    interpolated_rr = interp_func(interpolated_time)

    # Power spectral density estimation using Welch's method
    fxx, pxx = welch(interpolated_rr, fs=freq, nperseg=min(256, len(interpolated_rr)))

    # Define standard HRV frequency bands in Hz
    vlf_band = (0.003, 0.04)
    lf_band = (0.04, 0.15)
    hf_band = (0.15, 0.4)

    # Helper to calculate power in a given frequency band
    def band_power(freqs, power, band):
        mask = (freqs >= band[0]) & (freqs < band[1])
        return np.trapz(power[mask], freqs[mask])  # Trapezoidal integration

    # Convert the power from (s²) to (ms²), scale factor needed for final output
    scaling_factor = 1000 ** 2  # Convert seconds squared to milliseconds squared

    # Calculate power in each frequency band (now in ms²)
    vlf = band_power(fxx, pxx * scaling_factor, vlf_band)
    lf = band_power(fxx, pxx * scaling_factor, lf_band)
    hf = band_power(fxx, pxx * scaling_factor, hf_band)
    total = vlf + lf + hf
    vlf_pct = vlf / total
    lf_pct = lf / total
    hf_pct = hf / total

    # LF/HF ratio is often used as a sympathovagal balance indicator
    lf_hf = lf / hf if hf != 0 else np.nan

    # Return dictionary of frequency-domain metrics in ms²
    return {
        'VLF power': vlf,
        'LF power': lf,
        'HF power': hf,
        'Total power': total,
        'LF/HF ratio': lf_hf,
        'VLF perc': vlf_pct,
        'LF perc': lf_pct,
        'HF perc': hf_pct
    }


##create function to do manual peak review
class PeakReviewer:
    def __init__(self, signal, peaks, fs):
        self.signal = signal
        self.fs = fs
        self.fig, self.ax = plt.subplots()
        self.peaks = list(peaks)  # modifiable copy
        self.original_peaks = list(peaks)
        self.scatter = None
        self.adding_peak_mode = False
        self.cut_mode = False
        self.cut_start = None
        self.cut_end = None
        self.cut_lines = []  # Initialize the list for storing cut lines
        self.cut_history = [] # to store cut ranges

        self.plot_signal()

        # Add button for adding peaks
        add_ax = self.fig.add_axes([0.7, 0.01, 0.1, 0.05])  # x, y, width, height
        self.add_button = Button(add_ax, 'Add Peak')
        self.add_button.on_clicked(self.toggle_add_peak_mode)

        # Add button for 'Cut Region'
        cut_ax = self.fig.add_axes([0.81, 0.01, 0.1, 0.05])
        self.cut_button = Button(cut_ax, 'Cut Region')
        self.cut_button.on_clicked(self.toggle_cut_mode)

        # Add TextBox to show status (instructions, feedback)
        self.status_ax = self.fig.add_axes([0.01, 0.01, 0.65, 0.05])  # x, y, width, height
        self.status_box = TextBox(self.status_ax, '',
                                  initial="Instructions: Right-click to remove peaks. Shift+Left click to set start/end for cutting.")

        self.cid_click = self.fig.canvas.mpl_connect('button_press_event', self.onclick)

        print("Instructions:")
        print("- Right-click near a peak to remove it.")
        print("- Click 'Add Peak' and then left-click where you want to add a peak.")

    #function to plot ecg signal and its peaks
    def plot_signal(self):
        self.ax.plot(self.signal, label="ECG")
        self.scatter = self.ax.scatter(self.peaks, self.signal[self.peaks], c='r', label="Peaks")
        self.ax.legend()
        self.ax.set_title("Right-click to REMOVE peaks. Click button to ADD.")
        self.ax.set_xlabel("Samples")
        self.ax.set_ylabel("Amplitude")
        plt.subplots_adjust(bottom=0.15)  # leave space for button
        plt.show()

    #button to initiate add peak mode
    def toggle_add_peak_mode(self, event):
        self.adding_peak_mode = not self.adding_peak_mode
        print("Add mode ON" if self.adding_peak_mode else "Add mode OFF")

    #button to initate cut mode
    def toggle_cut_mode(self, event):
        """Toggle the cutting mode on and off."""
        self.cut_mode = not self.cut_mode
        print("Cut mode ON" if self.cut_mode else "Cut mode OFF")
        # Update the status box with the current mode
        self.status_box.set_val(
            "Cut mode ON. Shift + Left click to define start and end of cut." if self.cut_mode else "Cut mode OFF. Right-click to remove peaks.")

    def _draw_cut_line(self, x, color):
        """Draws a vertical line on the plot for start/end of the cut."""
        line = self.ax.axvline(x=x, color=color, linestyle='--', linewidth=1.5)
        self.cut_lines.append(line)  # Store the line object in the list
        plt.draw()

    def _apply_cut(self):
        """Applies the cut by removing the selected section from the signal and peaks."""
        start, end = sorted([self.cut_start, self.cut_end])  # Sort to ensure start is before end

        # Safety check to ensure bounds are valid
        start = max(0, start)
        end = min(len(self.signal), end)

        self.cut_history.append((start, end)) #save cuts
        self.signal = np.concatenate((self.signal[:start], self.signal[end:])) # Cut out the selected region from the signal
        self.peaks = [p for p in self.peaks if p < start or p > end]  # Remove peaks in the cut region

        # Adjust remaining peaks after the cut
        self.peaks = [p if p < start else p - (end - start) for p in self.peaks]

        self._clear_cut_lines()  # Clear the cut lines after applying the cut
        self.update_plot()  # Update the plot to reflect the changes

    #removes markers lines from the plot
    def _clear_cut_lines(self):
        for line in self.cut_lines:
            line.remove()
        self.cut_lines.clear()
        self.cut_start = None
        self.cut_end = None
        plt.draw()

    def onclick(self, event):
        if event.inaxes != self.ax or event.xdata is None:
            return  # Ignore clicks outside the plot area

        # Ensure xdata is an integer
        idx = int(event.xdata)  # Convert xdata (click position) to integer for indexing

        # Handle cut mode (shift + left click)
        if self.cut_mode and event.button == 1 and event.key == 'shift':
            if self.cut_start is None:
                self.cut_start = idx  # Set the start time (convert to integer)
                self._draw_cut_line(idx, 'green')  # Draw a green line for the start time
                self.status_box.set_val("Start time set. Now shift+left click to set stop time.")
            elif self.cut_end is None:
                self.cut_end = idx  # Set the end time (convert to integer)
                self._draw_cut_line(idx, 'red')  # Draw a red line for the end time

                # Additional check: Ensure start and end are within the valid range
                if 0 <= self.cut_start < len(self.signal) and 0 <= self.cut_end < len(self.signal):
                    self._apply_cut()  # Apply the cut
                    self.cut_mode = False  # Exit cut mode
                    self.status_box.set_val("Cut applied.")  # Update status box
                else:
                    self.status_box.set_val("Invalid cut range. Try again.")  # Invalid range
            return

        # Handle peak removal (right-click near peak)
        if event.button == 3:  # right-click to remove
            if self.peaks:
                closest_peak = min(self.peaks, key=lambda x: abs(x - idx))
                if abs(closest_peak - idx) < self.fs * 0.2:  # Within 200ms
                    self.ax.scatter(closest_peak, self.signal[closest_peak], c='yellow', s=100, label='Removed Peak')
                    plt.draw()
                    plt.pause(0.5)
                    if closest_peak in self.peaks:
                        self.peaks.remove(closest_peak)
                        print(f"Deleted peak at index {closest_peak}")
                    self.update_plot()

        # Handle peak addition (Left-click to add)
        elif event.button == 1 and self.adding_peak_mode:  # Left-click to add peak
            if 0 <= idx < len(self.signal):
                window_size = int(0.05 * self.fs)  # Define a window around the click (50ms)
                start = max(0, idx - window_size)
                end = min(len(self.signal), idx + window_size)
                local_peak_idx = start + self.signal[start:end].argmax()
                self.peaks.append(local_peak_idx)
                self.peaks.sort()
                print(f"Added peak at index {local_peak_idx}")
                self.update_plot()


    def update_plot(self):
        # Save current zoom/pan limits
        xlim = self.ax.get_xlim()
        ylim = self.ax.get_ylim()

        # Redraw plot contents without clearing zoom
        self.ax.clear()
        self.ax.plot(self.signal, label="ECG")
        self.scatter = self.ax.scatter(self.peaks, self.signal[self.peaks], c='r', label="Peaks")
        self.ax.legend()
        self.ax.set_title("Right-click to REMOVE peaks. Click button to ADD.")
        self.ax.set_xlabel("Samples")
        self.ax.set_ylabel("Amplitude")

        # Restore previous zoom/pan
        self.ax.set_xlim(xlim)
        self.ax.set_ylim(ylim)

        plt.draw()

    def get_cleaned_peaks(self):
        return self.peaks


