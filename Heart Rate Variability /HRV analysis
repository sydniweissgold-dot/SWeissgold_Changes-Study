# Calculate timestamps for RR intervals in each block
def rr_to_timestamps(start_idx, rr_list, sampling_freq, full_timestamps):
    if start_idx >= len(full_timestamps):
        raise IndexError(f"Start index {start_idx} is out of range for timestamps of length {len(full_timestamps)}")

    start_time = full_timestamps[start_idx]  # starting timestamp for block
    rr_sec = np.array(rr_list) / 1000.0
    cumulative_times = np.cumsum(rr_sec)
    return [start_time + timedelta(seconds=t) for t in cumulative_times]

