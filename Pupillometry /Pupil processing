def to_time(val):
    """Convert Excel values (string, Timestamp, or datetime) to datetime.time"""
    if isinstance(val, str):
        return datetime.strptime(val, "%H:%M:%S").time()
    elif isinstance(val, pd.Timestamp):
        return val.time()
    elif isinstance(val, datetime):
        return val.time()
    elif isinstance(val, time):  # already datetime.time
        return val
    else:
        raise ValueError(f"Unsupported type: {type(val)}")

