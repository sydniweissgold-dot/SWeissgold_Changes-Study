#first - define function to plot selected best eye w/ blinks (and remove blinks)
def select_best_eye(eye_df):
    """Determine which eye has fewer NaNs (more valid samples)."""
    left_valid = eye_df['pupil diameter left [mm]'].notna().sum()
    right_valid = eye_df['pupil diameter right [mm]'].notna().sum()

    if left_valid >= right_valid:
        best_eye = 'left'
        pupil_col = 'pupil diameter left [mm]'
    else:
        best_eye = 'right'
        pupil_col = 'pupil diameter right [mm]'

    print(f"Best eye selected: {best_eye} ({max(left_valid, right_valid)} valid samples pre-blink-removal)")

    summary = {
        'participant_id': participant_id,
        'left_valid_samples_pre': left_valid,
        'right_valid_samples_pre': right_valid,
        'best_eye': best_eye,
        'best_eye_valid_samples_pre': max(left_valid, right_valid),
    }

    return best_eye, pupil_col, summary


def plot_and_clean_best_eye(eye_df, blinks_df, start_timestamp, best_eye, pupil_col):
    """Plot best eye, highlight blinks, and remove blinks from pupil trace (WITH 100ms PADDING)."""
    #also returns clean df and # of NaNs AFTER blink removal
    df = eye_df.copy() #make copy to avoid messing w/ original
    #converts timestamps from nanoseconds -> seconds (relative to the start of the recording)
    df["timestamp_relative_s"] = (df["timestamp [ns]"] - start_timestamp) / 1e9
    blinks_df["start_relative_s"] = (blinks_df["start timestamp [ns]"] - start_timestamp) / 1e9
    blinks_df["end_relative_s"] = (blinks_df["end timestamp [ns]"] - start_timestamp) / 1e9

    ### PLOT ### set up 2 row plot which shares axes
    fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(18, 7), sharex=True, sharey=True)
    fig.suptitle(f"{participant_id} - {best_eye.capitalize()} Eye", fontsize=18)

    ##add padding (+/- 50ms)
    padding_s = 0.05

    # Top: Raw data with blink shading
    ax1.plot(df["timestamp_relative_s"], df[pupil_col], color="cornflowerblue", label="Raw pupil")
    #loop through blink events & shade gray
    for _, b in blinks_df.iterrows():
        start = b["start_relative_s"] - padding_s
        end = b["end_relative_s"] + padding_s
        ax1.axvspan(start, end, color="lightgray", alpha=0.5)
    #label and style plot
    ax1.set_title("Raw Pupil Diameter with Blinks Highlighted")
    ax1.set_ylabel("Pupil Diameter (mm)")
    ax1.grid(True)
    ax1.legend()

    # Bottom: Blinks removed
    clean_df = df.copy() #second copy created for blink-cleaning
    #loop through blinks & find timestamps corresponding to blink & remove that period
    for _, b in blinks_df.iterrows():
        blink_start = b["start_relative_s"] - padding_s
        blink_end = b["end_relative_s"] + padding_s
        blink_mask = (
            (clean_df["timestamp_relative_s"] >= blink_start) &
            (clean_df["timestamp_relative_s"] <= blink_end)
        )
        clean_df.loc[blink_mask, pupil_col] = np.nan

    #plot cleaned data
    ax2.plot(clean_df["timestamp_relative_s"], clean_df[pupil_col], color="mediumseagreen", label="Cleaned pupil")
    ax2.set_title("Pupil Diameter with Blinks Removed")
    ax2.set_xlabel("Time (s)")
    ax2.set_ylabel("Pupil Diameter (mm)")
    ax2.grid(True)
    ax2.legend()

    plt.tight_layout(rect=[0, 0, 1, 0.95]) #adjust spacing so titles don't overlap
    plt.show() #

    # Count valid samples AFTER blink removal
    data_valid_after_blinks_removed = clean_df[pupil_col].notna().sum()

    return clean_df, data_valid_after_blinks_removed



